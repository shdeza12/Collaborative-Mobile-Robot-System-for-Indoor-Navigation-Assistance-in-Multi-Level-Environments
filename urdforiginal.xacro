<?xml version="1.0"?>
<!--
  DonkeyCar URDF/Xacro para ROS2 + Gazebo
  ==========================================
  Plataforma: DonkeyCar 1/10 RC Car (chasis tipo Magnet Car o equivalente)
  Hardware objetivo: Raspberry Pi 4 + PCA9685 + cámara gran angular
  Compatible con: ROS2 Humble / Jazzy + Gazebo Classic (11) o Ignition/Gz

  Dimensiones basadas en chasis RC 1/10 escala real:
    - Largo total:       0.30 m
    - Ancho total:       0.18 m
    - Altura chasis:     0.06 m
    - Wheelbase (eje a eje): 0.20 m
    - Track width:       0.16 m
    - Radio rueda:       0.034 m (llanta 65mm diámetro)
    - Ancho rueda:       0.026 m

  Joints del modelo:
    - base_link          → chasis principal (link fijo al mundo vía joint flotante)
    - steering_link      → barra de dirección frontal (revolute, eje Z)
    - front_left_wheel   → rueda delantera izquierda (revolute, eje Y) ← traccionada por steering
    - front_right_wheel  → rueda delantera derecha  (revolute, eje Y) ← traccionada por steering
    - rear_left_wheel    → rueda trasera izquierda  (revolute, eje Y) ← drive motor
    - rear_right_wheel   → rueda trasera derecha    (revolute, eje Y) ← drive motor
    - camera_link        → cámara gran angular montada en la parte delantera-superior

  Plugins Gazebo incluidos:
    - libgazebo_ros_ackermann_drive.so  → control de velocidad + ángulo de giro
    - libgazebo_ros_camera.so           → publica imagen en /donkeycar/camera/image_raw
    - libgazebo_ros_joint_state_publisher.so → publica /joint_states

  Autor: Generado para el proyecto GED - USTA 2026
         Santiago Hernández Ávila / Jonny Alejandro Mejía León
-->

<robot name="donkeycar" xmlns:xacro="http://ros.org/wiki/xacro">
<link name="base_footprint"/>

<joint name="base_footprint_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

  <!-- ============================================================ -->
  <!--  1. PARÁMETROS GLOBALES (ajusta aquí si cambias el chasis)   -->
  <!-- ============================================================ -->

  <!-- Chasis -->
  <xacro:property name="base_length"    value="0.30"/>   <!-- m: largo total del chasis -->
  <xacro:property name="base_width"     value="0.18"/>   <!-- m: ancho total del chasis -->
  <xacro:property name="base_height"    value="0.04"/>   <!-- m: altura del cuerpo del chasis -->
  <xacro:property name="base_mass"      value="1.2"/>    <!-- kg: masa total estimada con Raspberry Pi y batería -->

  <!-- Ruedas -->
  <xacro:property name="wheel_radius"   value="0.034"/>  <!-- m: radio de llanta 65mm -->
  <xacro:property name="wheel_width"    value="0.026"/>  <!-- m: ancho de llanta -->
  <xacro:property name="wheel_mass"     value="0.05"/>   <!-- kg -->

  <!-- Distancias entre ejes -->
  <xacro:property name="wheelbase"      value="0.20"/>   <!-- m: distancia eje trasero a eje delantero -->
  <xacro:property name="track_width"    value="0.16"/>   <!-- m: distancia entre centros de ruedas izq/der -->

  <!-- Offsets de posición -->
  <xacro:property name="wheel_zoff"     value="${wheel_radius}"/>  <!-- altura del eje de rueda desde el suelo -->
  <xacro:property name="chassis_zoff"   value="${wheel_radius + 0.01}"/> <!-- fondo del chasis sobre el suelo -->

  <!-- Límites de dirección -->
  <xacro:property name="steer_limit"    value="0.5236"/>  <!-- rad (~30°) — máximo ángulo de giro -->
  <xacro:property name="steer_effort"   value="2.0"/>     <!-- N·m -->
  <xacro:property name="steer_vel"      value="3.0"/>     <!-- rad/s -->

  <!-- Límites de tracción -->
  <xacro:property name="drive_effort"   value="5.0"/>     <!-- N·m -->
  <xacro:property name="drive_vel"      value="20.0"/>    <!-- rad/s → ~2.4 m/s máx. -->

  <!-- Cámara -->
  <xacro:property name="cam_x"          value="0.12"/>    <!-- m: adelante del centro del chasis -->
  <xacro:property name="cam_z"          value="0.08"/>    <!-- m: altura sobre el chasis -->
  <xacro:property name="cam_tilt"       value="-0.2618"/> <!-- rad (~-15°): inclinación hacia abajo -->

  <!-- Constante auxiliar -->
  <xacro:property name="pi"             value="3.14159265358979"/>


  <!-- ============================================================ -->
  <!--  2. MACROS DE INERCIA                                        -->
  <!-- ============================================================ -->

  <!-- Inercia de caja sólida -->
  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(w*w+h*h)/12}" ixy="0" ixz="0"
        iyy="${m*(l*l+h*h)/12}" iyz="0"
        izz="${m*(l*l+w*w)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- Inercia de cilindro sólido (ruedas) — eje de rotación: Y -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
        iyy="${m*r*r/2}"          iyz="0"
        izz="${m*(3*r*r+h*h)/12}"/>
    </inertial>
  </xacro:macro>


  <!-- ============================================================ -->
  <!--  3. MACRO DE RUEDA (reutilizable para las 4 ruedas)          -->
  <!-- ============================================================ -->
  <!--
    Parámetros:
      prefix    → nombre del link: front_left, front_right, rear_left, rear_right
      x_reflect → +1 = delante, -1 = atrás
      y_reflect → +1 = izquierda, -1 = derecha
  -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <!-- Gazebo: fricción de llanta sobre piso -->
    <gazebo reference="${prefix}_wheel">
      <material>Gazebo/DarkGray</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>1.0</maxVel>
    </gazebo>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin
        xyz="${x_reflect * wheelbase/2} ${y_reflect * track_width/2} ${wheel_zoff}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.0"/>
      <limit effort="${drive_effort}" velocity="${drive_vel}"/>
    </joint>
  </xacro:macro>


  <!-- ============================================================ -->
  <!--  4. BASE LINK (chasis principal)                             -->
  <!-- ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_zoff + base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.15 0.45 0.85 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_zoff + base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" l="${base_length}" w="${base_width}" h="${base_height}"/>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>


  <!-- ============================================================ -->
  <!--  5. RUEDAS TRASERAS (tracción: reciben cmd de velocidad)     -->
  <!-- ============================================================ -->
  <xacro:wheel prefix="rear_left"  x_reflect="-1" y_reflect="1"/>
  <xacro:wheel prefix="rear_right" x_reflect="-1" y_reflect="-1"/>


  <!-- ============================================================ -->
  <!--  6. DIRECCIÓN (steering_link + ruedas delanteras)           -->
  <!-- ============================================================ -->

  <!--
    El steering_link es un link auxiliar invisible que centraliza
    el ángulo de giro. Las ruedas delanteras se conectan a él con
    joints fixed (aproximación simplificada para el plugin Ackermann).
    Para simulación Ackermann completa con toe-in/toe-out, reemplazar
    con joints revolute independientes por rueda y usar mimic joints.
  -->

  <!-- Link de dirección (invisible, punto de pivote) -->
  <link name="steering_link">
    <visual>
      <geometry>
        <box size="0.02 ${track_width} 0.01"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 ${track_width} 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Joint de dirección: revolute sobre eje Z (giro izquierda/derecha) -->
  <joint name="steering_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="steering_link"/>
    <origin xyz="${wheelbase/2} 0 ${wheel_zoff}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit
      lower="${-steer_limit}"
      upper="${steer_limit}"
      effort="${steer_effort}"
      velocity="${steer_vel}"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Rueda delantera izquierda -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
  </link>

  <gazebo reference="front_left_wheel">
    <material>Gazebo/DarkGray</material>
    <mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="steering_link"/>
    <child  link="front_left_wheel"/>
    <origin xyz="0 ${track_width/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.0"/>
    <limit effort="${drive_effort}" velocity="${drive_vel}"/>
  </joint>

  <!-- Rueda delantera derecha -->
  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
  </link>

  <gazebo reference="front_right_wheel">
    <material>Gazebo/DarkGray</material>
    <mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="steering_link"/>
    <child  link="front_right_wheel"/>
    <origin xyz="0 ${-track_width/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.0"/>
    <limit effort="${drive_effort}" velocity="${drive_vel}"/>
  </joint>


  <!-- ============================================================ -->
  <!--  7. CÁMARA                                                   -->
  <!-- ============================================================ -->

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin
      xyz="${cam_x} 0 ${chassis_zoff + base_height + cam_z}"
      rpy="0 ${cam_tilt} 0"/>
  </joint>

  <!-- Link óptico de la cámara (frame estándar ROS: x=adelante, z=arriba) -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- Plugin de cámara Gazebo -->
  <gazebo reference="camera_link">
    <material>Gazebo/White</material>
    <sensor type="camera" name="donkeycar_camera">
      <update_rate>30.0</update_rate>
      <camera name="main_camera">
        <horizontal_fov>1.8326</horizontal_fov>  <!-- ~105° FOV gran angular -->
        <image>
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>30</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/donkeycar</namespace>
          <remapping>image_raw:=camera/image_raw</remapping>
          <remapping>camera_info:=camera/camera_info</remapping>
        </ros>
        <camera_name>main_camera</camera_name>
        <frame_name>camera_optical_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>


  <!-- ============================================================ -->
  <!--  8. PLUGIN DE CONTROL ACKERMANN (drive + steering)          -->
  <!-- ============================================================ -->
  <!--
    El plugin recibe en /donkeycar/cmd_ackermann un mensaje
    ackermann_msgs/AckermannDriveStamped con:
      .drive.speed          → velocidad deseada (m/s)
      .drive.steering_angle → ángulo de giro (rad)

    Publica odometría en /donkeycar/odom y transforma base_link→odom.
  -->
  <gazebo>
    <plugin name="gazebo_ros_ackermann_drive" filename="libgazebo_ros_ackermann_drive.so">
      <ros>
        <namespace>/donkeycar</namespace>
        <remapping>cmd_ackermann:=cmd_ackermann</remapping>
        <remapping>odom:=odom</remapping>
        <remapping>distance:=distance</remapping>
      </ros>

      <!-- Joints de tracción (ruedas traseras) -->
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <!-- Joint de dirección -->
      <steering_joint>steering_joint</steering_joint>

      <!-- Geometría del vehículo -->
      <wheel_separation>${track_width}</wheel_separation>
      <wheel_diameter>${2*wheel_radius}</wheel_diameter>
      <wheelbase>${wheelbase}</wheelbase>

      <!-- Límites dinámicos -->
      <max_steer>${steer_limit}</max_steer>
      <max_speed>3.0</max_speed>           <!-- m/s -->
      <max_wheel_torque>${drive_effort}</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>

      <!-- Odometría -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>


  <!-- ============================================================ -->
  <!--  9. PUBLICADOR DE ESTADOS DE JOINTS                         -->
  <!-- ============================================================ -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/donkeycar</namespace>
        <remapping>joint_states:=joint_states</remapping>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>steering_joint</joint_name>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
