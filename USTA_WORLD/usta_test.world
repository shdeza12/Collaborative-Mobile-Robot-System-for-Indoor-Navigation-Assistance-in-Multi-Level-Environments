<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="usta_test">
    
    <!-- Iluminación y suelo base -->
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>
    
    <!-- Tu modelo del edificio USTA -->
    <include>
      <uri>model://Prueba1</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>
    
    <!-- Configuración de física estándar -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    
  </world>
</sdf>
